# Importamos la clase Mascota desde el archivo mascota.py
from mascota import Mascota

# Creamos dos objetos de la clase Mascota
mascota1 = Mascota("Luna", "Gato", 3)
mascota2 = Mascota("Max", "Perro", 5)

# Mostramos la información de la primera mascota
mascota1.mostrar_informacion()
mascota1.hacer_sonido()

# Mostramos la información de la segunda mascota
mascota2.mostrar_informacion()
mascota2.hacer_sonido()